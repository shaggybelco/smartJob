generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  APPLICANT
  RECRUITER
}

enum CompanyMembership {
  PENDING
  APPROVED
  ADMIN
}

enum JobStatus {
  OPEN
  CLOSED
}

enum AppStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum EventType {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  NOTE
}

model User {
  id                       String           @id @default(cuid())
  email                    String           @unique
  passwordHash             String
  name                     String
  headline                 String?
  bio                      String?
  role                     Role               @default(APPLICANT)
  companyId                String?
  company                  Company?           @relation(fields: [companyId], references: [id])
  companyMembership        CompanyMembership?
  emailVerified            Boolean          @default(false)
  emailVerificationToken   String?          @unique
  passwordResetToken       String?          @unique
  passwordResetExpiresAt   DateTime?
  tokenVersion             Int              @default(0)
  createdAt                DateTime         @default(now())
  searchable               Boolean          @default(true)
  applications             Application[]
  postedJobs               Job[]            @relation("JobPostedBy")
  jobApps                  JobApplication[] @relation("JobAppApplicant")
  savedJobs                SavedJob[]
  skills                   UserSkill[]
  experiences              WorkExperience[]
  chatThreadsAsRecruiter   ChatThread[]     @relation("ChatRecruiter")
  chatThreadsAsApplicant   ChatThread[]     @relation("ChatApplicant")
  chatMessagesSent         ChatMessage[]
  pushSubscriptions        PushSubscription[]
}

model ChatThread {
  id                String        @id @default(cuid())
  recruiterId       String
  recruiter         User          @relation("ChatRecruiter", fields: [recruiterId], references: [id], onDelete: Cascade)
  applicantId       String
  applicant         User          @relation("ChatApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  lastMessageAt     DateTime?
  recruiterArchived Boolean       @default(false)
  applicantArchived Boolean       @default(false)
  messages          ChatMessage[]

  @@unique([recruiterId, applicantId])
  @@index([recruiterId, lastMessageAt])
  @@index([applicantId, lastMessageAt])
}

model ChatMessage {
  id          String           @id @default(cuid())
  threadId    String
  thread      ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body        String
  createdAt   DateTime         @default(now())
  readAt      DateTime?
  attachments ChatAttachment[]

  @@index([threadId, createdAt])
}

model ChatAttachment {
  id         String      @id @default(cuid())
  messageId  String
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  storageKey String
  filename   String
  mimeType   String
  size       Int
  createdAt  DateTime    @default(now())

  @@index([messageId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  authKey   String
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserSkill {
  userId  String
  skillId String
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([skillId])
}

model WorkExperience {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  company     String
  location    String?
  description String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([userId, startDate])
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  description String?
  createdAt   DateTime @default(now())
  recruiters  User[]
  jobs        Job[]
}

model Skill {
  id    String  @id @default(cuid())
  name  String  @unique
  slug  String  @unique
  jobs  JobSkill[]
  users UserSkill[]
}

model JobSkill {
  jobId   String
  skillId String
  job     Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@index([skillId])
}

model Job {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedById   String
  postedBy     User             @relation("JobPostedBy", fields: [postedById], references: [id])
  title        String
  description  String
  location     String?
  remote       Boolean          @default(false)
  salaryMin    Int?
  salaryMax    Int?
  status       JobStatus        @default(OPEN)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]
  questions    JobQuestion[]
  skills       JobSkill[]
  savedBy      SavedJob[]

  @@index([status, createdAt])
  @@index([companyId])
}

model JobQuestion {
  id       String   @id @default(cuid())
  jobId    String
  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  prompt   String
  required Boolean  @default(false)
  position Int      @default(0)
  answers  ApplicationAnswer[]

  @@index([jobId, position])
}

model ApplicationAnswer {
  id               String         @id @default(cuid())
  jobApplicationId String
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  questionId       String
  question         JobQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer           String

  @@unique([jobApplicationId, questionId])
}

model SavedJob {
  userId  String
  jobId   String
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job     Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  savedAt DateTime @default(now())

  @@id([userId, jobId])
  @@index([userId, savedAt])
}

model JobApplication {
  id               String              @id @default(cuid())
  jobId            String
  job              Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId      String
  applicant        User                @relation("JobAppApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  coverLetter      String?
  resumeUrl        String?
  resumeStorageKey String?
  resumeFilename   String?
  resumeMimeType   String?
  resumeSize       Int?
  status           AppStatus           @default(APPLIED)
  recruiterNote    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  trackerEntry     Application?
  answers          ApplicationAnswer[]

  @@unique([jobId, applicantId])
  @@index([jobId, status])
  @@index([applicantId])
}

model Application {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          String
  role             String
  status           AppStatus       @default(APPLIED)
  source           String?
  salary           Int?
  jobUrl           String?
  location         String?
  notes            String?
  appliedAt        DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  jobApplicationId String?         @unique
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  events           Event[]
  reminders        Reminder[]

  @@index([userId, status])
  @@index([userId, appliedAt])
}

model Event {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          EventType
  occurredAt    DateTime    @default(now())
  notes         String?

  @@index([applicationId, occurredAt])
}

model Reminder {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  dueAt         DateTime
  message       String
  completed     Boolean     @default(false)

  @@index([applicationId, dueAt])
}
